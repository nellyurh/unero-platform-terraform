# Single-account model: apply ONCE with human/bootstrap credentials. No account IDs needed
# here — the config discovers the account via the caller identity.
github_org   = "nellyurh"
github_repo  = "unero-platform-terraform"
environments = ["dev", "staging", "production"]
# state_bucket_name / lock_table_name default to the platform names; override if different.
# If the account already has a GitHub OIDC provider:
# create_oidc_provider = false
# oidc_provider_arn    = "arn:aws:iam::<ACCOUNT_ID>:oidc-provider/token.actions.githubusercontent.com"
